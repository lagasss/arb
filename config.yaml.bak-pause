yield_monitoring:
  min_divergence_bps: 10    # global floor; per-pair min_divergence_bps overrides lower
  min_profit_usd: 5         # $5 minimum — wstETH arb at 2 bps on $50k = $10
  pairs:
    # NOTE: lido_wsteth removed — bridged wstETH on Arbitrum is a plain ERC-20,
    # stEthPerToken() is not available. wstETH arb here is purely AMM-to-AMM (the cycle cache covers it).

    # Chainlink oracle — wstETH/ETH feed on Arbitrum (returns ETH per wstETH, 18 decimals)
    # wstETH accumulates staking yield; AMM price lags the oracle → recurring arb
    # Typical divergence: 1-3 bps. Profitable at >3 bps with large flash loan (~$500k).
    - base_address:     "0x82aF49447D8a07e3bd95BD0d56f35241523fBab1"  # WETH
      wrapper_address:  "0x5979D7b546E38E414F7E9822514be443A4800529"  # wstETH
      protocol: "chainlink"
      rate_contract:    "0xb523AE262D20A936BC152e6023996e46FDC2A95D"  # Chainlink wstETH/ETH Arbitrum
      max_stale_secs:   86400  # wstETH/ETH feed heartbeat is 24h
      min_divergence_bps: 3  # log when > 3 bps — break-even ~$15 at $50k, actionable at $150k+

    # Aave V3 — aTokens accrue interest every block; rate readable from AavePool contract
    - base_address:    "0xaf88d065e77c8cC2239327C5EDb3A432268e5831"  # USDC
      wrapper_address: "0x724dc807b04555b71ed48a6896b6F41593b8C637"  # aArbUSDC
      protocol: "aave_v3"
      rate_contract:   "0x794a61358D6845594F94dc1DB02A252b5b4814aD"  # Aave V3 Pool Arbitrum
    - base_address:    "0x82aF49447D8a07e3bd95BD0d56f35241523fBab1"  # WETH
      wrapper_address: "0xe50fA9b3c56FfB159cB0FCA61F5c9D750e8128c8"  # aArbWETH
      protocol: "aave_v3"
      rate_contract:   "0x794a61358D6845594F94dc1DB02A252b5b4814aD"
    - base_address:    "0xFd086bC7CD5C481DCC9C85ebE478A1C0b69FCbb9"  # USDT
      wrapper_address: "0x6ab707Aca953eDAeFBc4fD23bA73294241490620"  # aArbUSDT
      protocol: "aave_v3"
      rate_contract:   "0x794a61358D6845594F94dc1DB02A252b5b4814aD"

    # NOTE: sUSDe erc4626 removed — bridged sUSDe on Arbitrum is not a redeemable vault.
    # Mainnet sUSDe at 0x9D39A5DE30e57443BfF2A8307A4256c8797A3497 supports convertToAssets.

  ramses_v3:    "0xd0019e86edB35E1fedaaB03aED5c3c60f115d28b"  # docs.ramses.exchange, 3423 bytes bytecode
  ramses_v2:    "0xADd32480630A16dfAcEe6eeFcB3ab2181449Dc3B"  # docs.ramses.exchange
  camelot_v3:   "0x1a3c9B1d2F0529D97f2afC5136Cc23e58f1FD35B"  # docs.camelot.exchange AMMv3 AlgebraFactory, 14031 bytes
  camelot:      "0x6EcCab422D763aC031210895C81787E87B43A652"
  # DISABLED 2026-04-12: TraderJoe V2 uses Liquidity Book (discrete price bins),
  # not x*y=k. Our simulator routes TJoe through UniswapV2Sim which is the wrong
  # math — any TJoe cycle would produce incorrect sim outputs. Disabled until a
  # LiquidityBookSim is implemented. The two existing TJoe pools ($300/$116 TVL)
  # are already excluded by the $5k absolute TVL floor.
  # trader_joe: "0x8909Dc15e40173Ff4699343b6eB8132c65e18eC6"

